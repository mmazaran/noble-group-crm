# Copy this file to .env.local and fill in values from your Supabase project
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only used in server-side scripts (e.g. inviting users), NEVER exposed to the browser.
# Keep this out of any NEXT_PUBLIC_ variable and never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
